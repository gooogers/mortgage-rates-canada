---
import Base from "@layouts/Base.astro";
import Breadcrumb from "@components/Breadcrumb.astro";
import { breadcrumbSchema, type BreadcrumbItem } from "@lib/schemas";
import { GLOSSARY_ENTRIES, slugifyTerm } from "../data/glossary";

const sorted = [...GLOSSARY_ENTRIES].sort((a, b) => a.term.localeCompare(b.term));
const indexed = sorted.map((e) => ({ ...e, id: e.id ?? slugifyTerm(e.term) }));

const breadcrumbTrail: BreadcrumbItem[] = [
  { name: "Home", path: "/" },
  { name: "Glossary", path: "/glossary" },
];
const pageSchemas = [breadcrumbSchema(breadcrumbTrail)];
---

<Base
  title="Canadian Mortgage Glossary | Canadian Rates"
  description="Plain-English definitions of Canadian mortgage terms — IRD, GDS, TDS, posted vs discounted rates, CMHC, the stress test, and more."
  canonical="https://canadianrates.ca/glossary"
  schemas={pageSchemas}
>
  <Breadcrumb trail={breadcrumbTrail} />
  <h1>Canadian mortgage glossary</h1>
  <p class="page-meta">Last reviewed May 1, 2026.</p>
  <p class="muted">
    Plain-English definitions for the terms that come up when you're getting
    a Canadian mortgage. Linked entries deepen the definition with a guide.
  </p>

  <nav class="glossary-jump" aria-label="Jump to term">
    {indexed.map((e) => (
      <a href={`#${e.id}`}>{e.term}</a>
    ))}
  </nav>

  <dl class="glossary">
    {indexed.map((e) => (
      <div class="glossary-entry" id={e.id}>
        <dt class="glossary-term">{e.term}</dt>
        <dd class="glossary-def">
          <p>{e.definition}</p>
          {e.link && (
            <p class="glossary-link">
              <a href={e.link.href}>→ {e.link.label}</a>
            </p>
          )}
        </dd>
      </div>
    ))}
  </dl>
</Base>

<style>
  .muted {
    color: var(--color-muted);
    font-size: 0.95rem;
    line-height: 1.55;
  }
  .page-meta {
    color: var(--color-muted);
    font-size: 0.9rem;
    margin: 0 0 1rem;
  }
  .glossary-jump {
    margin: 1.25rem 0 2rem;
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border, #e0e4e8);
    border-radius: 6px;
    background: var(--color-surface, #fafbfc);
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
    font-size: 0.9rem;
  }
  .glossary-jump a {
    white-space: nowrap;
  }
  .glossary {
    margin: 1.5rem 0;
  }
  .glossary-entry {
    padding: 1rem 0;
    border-bottom: 1px solid var(--color-border, #e0e4e8);
  }
  .glossary-entry:target {
    background: #fff8e1;
    margin: 0 -0.75rem;
    padding-left: 0.75rem;
    padding-right: 0.75rem;
    border-radius: 4px;
  }
  .glossary-term {
    font-size: 1.1rem;
    font-weight: 700;
    margin: 0 0 0.4rem;
  }
  .glossary-def {
    margin: 0;
  }
  .glossary-def p {
    margin: 0 0 0.4rem;
    line-height: 1.6;
  }
  .glossary-link {
    margin-top: 0.4rem;
    font-size: 0.9rem;
  }
</style>
