---
import Base from "@layouts/Base.astro";
import Breadcrumb from "@components/Breadcrumb.astro";
import Disclaimer from "@components/Disclaimer.astro";
import LenderBadge from "@components/LenderBadge.astro";
import { formatPercent, formatTermLabel, formatUpdatedAt } from "@lib/format";
import { bestRateForTerm, loadRatesData, type Term } from "@lib/rates";
import { breadcrumbSchema, faqPageSchema, type BreadcrumbItem } from "@lib/schemas";

interface OtherTerm {
  slug: string;
  term: Term;
  blurb: string;
}

// The five less-common terms. The popular three (3yr fixed, 5yr fixed,
// variable) get top-level menu items; everything else lives here.
const OTHER_TERMS: OtherTerm[] = [
  {
    slug: "1-year-fixed",
    term: "1yr_fixed",
    blurb: "A short fixed term for borrowers in transition or those expecting cuts within 12 months. Often more expensive than longer fixed terms unless the yield curve is inverted.",
  },
  {
    slug: "2-year-fixed",
    term: "2yr_fixed",
    blurb: "Rare in Canada — most lenders quote 1, 3, or 5. Worth a look only when pricing puts it below the 3-year and your timeline is genuinely 24 months.",
  },
  {
    slug: "4-year-fixed",
    term: "4yr_fixed",
    blurb: "Less liquid bond market behind it, so lenders interpolate from 3- and 5-year. Rarely the cheapest option, but occasionally lands below both adjacent terms.",
  },
  {
    slug: "7-year-fixed",
    term: "7yr_fixed",
    blurb: "Carries a premium over 5-year for two extra years of certainty. Worth it only if the premium is small and you genuinely cannot tolerate a renewal in five years.",
  },
  {
    slug: "10-year-fixed",
    term: "10yr_fixed",
    blurb: "Federal law caps the prepayment penalty at three months' interest after year 5, so functionally a 10-year is a 5-year with worse pricing. Almost never the math winner.",
  },
];

const data = await loadRatesData();
const rows = OTHER_TERMS.map((t) => ({
  ...t,
  best: bestRateForTerm(data, t.term),
}));

const breadcrumbTrail: BreadcrumbItem[] = [
  { name: "Home", path: "/" },
  { name: "Rates", path: "/rates" },
  { name: "Other terms", path: "/rates/other-terms" },
];

const FAQS = [
  {
    q: "Which mortgage terms are 'less common' in Canada?",
    a: "1, 2, 4, 7, and 10-year fixed. The popular three are 5-year fixed, 3-year fixed, and variable — that's roughly 90% of new originations.",
  },
  {
    q: "When is a 1-year fixed worth a look?",
    a: "When you're in a transitional life situation (selling, divorcing, relocating within the year) or you have specific evidence rates will be materially lower in 12 months and want to renew into them.",
  },
  {
    q: "Why is the 10-year fixed almost never the math winner?",
    a: "Section 10 of the federal Interest Act caps the prepayment penalty at three months' interest for fixed terms longer than 5 years, but only after year 5. So functionally a 10-year fixed is a 5-year with the option to keep going at the same rate — but you pay a premium of 30-100bps over a 5-year fixed for that option, which usually outweighs the value.",
  },
];

const pageSchemas = [breadcrumbSchema(breadcrumbTrail), faqPageSchema(FAQS)];
---

<Base
  title="Other mortgage terms (1, 2, 4, 7, 10 yr)"
  description="Best rates for the less-common Canadian mortgage terms — 1, 2, 4, 7, and 10-year fixed. When each is the right pick versus 3-year, 5-year, or variable."
  canonical="https://canadianrates.ca/rates/other-terms"
  schemas={pageSchemas}
>
  <Breadcrumb trail={breadcrumbTrail} />
  <h1>Other mortgage terms</h1>
  <p class="muted">Updated {formatUpdatedAt(data.updated_at)}.</p>

  <p class="lede">
    Most Canadians sign a 5-year fixed, a 3-year fixed, or a variable. The
    terms below — 1, 2, 4, 7, and 10 year fixed — are less common but
    occasionally the right pick. Each links to its full ranking.
  </p>

  <Disclaimer variant="rate" />

  <table class="other-table">
    <thead>
      <tr>
        <th>Term</th>
        <th>Best discounted rate</th>
        <th>Lender</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      {rows.map(({ slug, term, best }) => (
        <tr>
          <td><a href={`/rates/${slug}`}><strong>{formatTermLabel(term)}</strong></a></td>
          <td class="other-table__rate">
            {best ? <strong>{formatPercent(best.rate.discounted ?? best.rate.posted)}</strong> : "—"}
          </td>
          <td>
            {best ? (
              <span class="other-table__lender">
                <LenderBadge slug={best.lender.slug} name={best.lender.name} />
                <a href={`/lenders/${best.lender.slug}`}>{best.lender.name}</a>
              </span>
            ) : (
              "—"
            )}
          </td>
          <td><a href={`/rates/${slug}`}>See all →</a></td>
        </tr>
      ))}
    </tbody>
  </table>

  <section class="other-notes">
    {rows.map(({ slug, term, blurb }) => (
      <div class="other-note">
        <h2><a href={`/rates/${slug}`}>{formatTermLabel(term)}</a></h2>
        <p>{blurb}</p>
      </div>
    ))}
  </section>

  <section class="other-faqs">
    <h2>Common questions</h2>
    {FAQS.map((qa) => (
      <div class="other-faq">
        <h3>{qa.q}</h3>
        <p>{qa.a}</p>
      </div>
    ))}
  </section>
</Base>

<style>
  .muted {
    color: var(--color-muted);
    font-size: 0.95rem;
  }
  .lede {
    margin: 1rem 0 1.5rem;
    line-height: 1.6;
  }
  .other-table {
    width: 100%;
    border-collapse: collapse;
    margin: 1rem 0 2rem;
  }
  .other-table th,
  .other-table td {
    padding: 0.6rem 0.5rem;
    border-bottom: 1px solid var(--color-border, #e0e4e8);
    text-align: left;
  }
  .other-table th {
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--color-muted);
  }
  .other-table__rate {
    font-variant-numeric: tabular-nums;
  }
  .other-table__lender {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .other-notes {
    display: grid;
    gap: 1.25rem;
    margin: 2rem 0;
  }
  .other-note h2 {
    margin: 0 0 0.4rem;
    font-size: 1.05rem;
  }
  .other-note p {
    margin: 0;
    line-height: 1.55;
    color: var(--color-fg, #222);
  }
  .other-faqs {
    margin: 2.5rem 0 0;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border, #e0e4e8);
  }
  .other-faqs > h2 {
    margin: 0 0 1rem;
    font-size: 1.1rem;
  }
  .other-faq {
    margin-bottom: 1.25rem;
  }
  .other-faq h3 {
    margin: 0 0 0.3rem;
    font-size: 1rem;
  }
  .other-faq p {
    margin: 0;
    line-height: 1.55;
  }
</style>
