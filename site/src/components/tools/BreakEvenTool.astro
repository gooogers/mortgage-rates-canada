---
import ToolFrame from "@components/ToolFrame.astro";
import { bestRateForTerm, loadRatesData } from "@lib/rates";

const data = await loadRatesData();
const bestFixed = bestRateForTerm(data, "5yr_fixed");
const bestVar = bestRateForTerm(data, "variable");
const defaultFixed = bestFixed?.rate.discounted ?? 4.79;
const defaultVar = bestVar?.rate.discounted ?? 4.20;
---

<ToolFrame title="Fixed vs variable mortgage calculator" toolId="break-even">
  <div slot="inputs">
    <form class="be-form" data-default-fixed={defaultFixed} data-default-var={defaultVar}>
      <label>Loan amount
        <input type="number" name="loanAmount" min="0" step="1000" value="500000" required />
      </label>
      <label>Amortization (years)
        <select name="amortizationYears">
          <option value="20">20</option>
          <option value="25" selected>25</option>
          <option value="30">30</option>
        </select>
      </label>
      <label>Term length (years)
        <select name="termYears">
          <option value="1">1</option>
          <option value="2">2</option>
          <option value="3">3</option>
          <option value="4">4</option>
          <option value="5" selected>5</option>
          <option value="7">7</option>
          <option value="10">10</option>
        </select>
      </label>
      <label>Fixed rate (%)
        <input type="number" name="fixedRate" min="0" max="20" step="0.01" value={defaultFixed} required />
      </label>
      <label>Variable rate (%)
        <input type="number" name="variableRate" min="0" max="20" step="0.01" value={defaultVar} required />
      </label>
      <fieldset class="be-presets">
        <legend>Scenario</legend>
        <div class="be-presets__row">
          <button type="button" data-preset="hold">Hold steady</button>
          <button type="button" data-preset="cuts">Gradual cuts</button>
          <button type="button" data-preset="rise">Gradual rise</button>
          <button type="button" data-preset="hike">Sharp hike</button>
        </div>
      </fieldset>
      <label>Variable rate ends up <span class="be-help">(change in % points)</span>
        <input type="number" name="variableRateTargetChange" min="-3" max="3" step="0.25" value="0" required />
      </label>
      <fieldset class="be-pace">
        <legend>How quickly?</legend>
        <label><input type="radio" name="paceMonths" value="0" checked /> Immediately</label>
        <label><input type="radio" name="paceMonths" value="12" /> Over 1 year</label>
        <label><input type="radio" name="paceMonths" value="24" /> Over 2 years</label>
        <label><input type="radio" name="paceMonths" value="60" /> Over 5 years</label>
      </fieldset>
      <button type="button" class="tool__use-rates" data-action="use-rates">Use today's rates</button>
    </form>
  </div>

  <div slot="result">
    <p class="be-headline" data-result="headline">—</p>
    <p class="be-sub" data-result="sub"></p>
    <svg class="be-chart" data-result="chart" viewBox="0 0 360 230" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Cumulative interest over the term for fixed vs variable mortgage."></svg>
    <div class="be-legend">
      <span class="be-legend__item be-legend__item--fixed">Fixed</span>
      <span class="be-legend__item be-legend__item--variable">Variable</span>
    </div>
    <dl class="be-totals">
      <div><dt>Fixed total interest</dt><dd data-result="fixed-total">—</dd></div>
      <div><dt>Variable total interest</dt><dd data-result="var-total">—</dd></div>
    </dl>
  </div>

  <div slot="details">
    <table class="be-detail">
      <tbody>
        <tr><td>Fixed payment</td><td data-detail="fixed-payment">—</td></tr>
        <tr><td>Variable initial payment</td><td data-detail="var-init">—</td></tr>
        <tr><td>Variable ending payment</td><td data-detail="var-end">—</td></tr>
        <tr><td>Fixed total interest (5 yr)</td><td data-detail="fixed-int">—</td></tr>
        <tr><td>Variable total interest (5 yr)</td><td data-detail="var-int">—</td></tr>
      </tbody>
    </table>
  </div>
</ToolFrame>

<script>
  import { compareBreakEven } from "@lib/breakEven";
  import { formatCurrency } from "@lib/format";

  const form = document.querySelector<HTMLFormElement>(".be-form");
  if (!form) throw new Error("break-even form not found");
  const root = form.closest('[data-tool-id="break-even"]') as HTMLElement;

  function num(name: string): number {
    return parseFloat((form!.elements.namedItem(name) as HTMLInputElement).value);
  }
  function pickedPace(): number {
    const checked = form!.querySelector<HTMLInputElement>('input[name="paceMonths"]:checked');
    return checked ? parseInt(checked.value, 10) : 0;
  }
  function setPace(months: number) {
    const radio = form!.querySelector<HTMLInputElement>(`input[name="paceMonths"][value="${months}"]`);
    if (radio) radio.checked = true;
  }
  function setNum(name: string, value: number) {
    (form!.elements.namedItem(name) as HTMLInputElement).value = String(value);
  }
  function setText(sel: string, txt: string) {
    const el = root.querySelector(sel);
    if (el) el.textContent = txt;
  }

  function recalc() {
    const termYears = num("termYears");
    const horizonMonths = termYears * 12;
    const r = compareBreakEven({
      loanAmount: num("loanAmount"),
      amortizationYears: num("amortizationYears"),
      fixedRate: num("fixedRate"),
      variableRate: num("variableRate"),
      variableRateTargetChange: num("variableRateTargetChange"),
      paceMonths: pickedPace(),
      horizonMonths,
    });
    const winner = r.winner === "tie" ? "tied" : r.winner;
    setText("[data-result='headline']", `${winner === "tied" ? "It's a tie" : capitalize(winner) + " wins"}`);
    setText(
      "[data-result='sub']",
      r.winner === "tie"
        ? `Total interest over ${termYears} years is essentially equal.`
        : `Saves ${formatCurrency(r.savingsAmount)} in interest over ${termYears} years vs the other option.`,
    );
    setText("[data-result='fixed-total']", formatCurrency(r.fixedTotalInterest));
    setText("[data-result='var-total']", formatCurrency(r.variableTotalInterest));
    setText("[data-detail='fixed-payment']", formatCurrency(r.fixedPayment, { cents: true }));
    setText("[data-detail='var-init']", formatCurrency(r.variableInitialPayment, { cents: true }));
    setText("[data-detail='var-end']", formatCurrency(r.variableEndingPayment, { cents: true }));
    setText("[data-detail='fixed-int']", formatCurrency(r.fixedTotalInterest));
    setText("[data-detail='var-int']", formatCurrency(r.variableTotalInterest));
    drawChart(r.fixedCumulativeInterest, r.variableCumulativeInterest, termYears);
  }

  const PRESETS: Record<string, { target: number; pace: number }> = {
    hold: { target: 0, pace: 0 },
    cuts: { target: -1.5, pace: 24 },
    rise: { target: 1.5, pace: 24 },
    hike: { target: 2.0, pace: 0 },
  };
  function applyPreset(key: string) {
    const p = PRESETS[key];
    if (!p) return;
    setNum("variableRateTargetChange", p.target);
    setPace(p.pace);
    recalc();
  }

  function drawChart(fixedSeries: number[], varSeries: number[], termYears: number) {
    const svg = root.querySelector<SVGSVGElement>("[data-result='chart']");
    if (!svg) return;
    const W = 360, H = 230;
    const PAD_L = 56, PAD_R = 10, PAD_T = 12, PAD_B = 50;
    const innerW = W - PAD_L - PAD_R;
    const innerH = H - PAD_T - PAD_B;
    const n = Math.max(fixedSeries.length, varSeries.length);
    const maxY = Math.max(
      fixedSeries[fixedSeries.length - 1] ?? 0,
      varSeries[varSeries.length - 1] ?? 0,
      1,
    );
    const x = (i: number) => PAD_L + (i / (n - 1)) * innerW;
    const y = (v: number) => PAD_T + innerH - (v / maxY) * innerH;
    const toPath = (series: number[]) =>
      series.map((v, i) => `${i === 0 ? "M" : "L"} ${x(i).toFixed(1)} ${y(v).toFixed(1)}`).join(" ");

    const yTicks = 4;
    const yTickValues = Array.from({ length: yTicks + 1 }, (_, i) => (maxY * i) / yTicks);
    const fmtTick = (v: number) =>
      v >= 1000 ? `$${Math.round(v / 1000)}k` : `$${Math.round(v)}`;

    // Year-aligned x-ticks. 1y goes 0..12, 2y goes 0,12,24, etc.
    const xTicks: number[] = [];
    for (let y = 0; y <= termYears; y++) xTicks.push(y * 12);

    const gridLines = yTickValues
      .map((v) => `<line x1="${PAD_L}" x2="${W - PAD_R}" y1="${y(v).toFixed(1)}" y2="${y(v).toFixed(1)}" stroke="#eee" stroke-width="1" />`)
      .join("");
    const yLabels = yTickValues
      .map((v) => `<text x="${PAD_L - 6}" y="${(y(v) + 4).toFixed(1)}" text-anchor="end" font-size="10" fill="#666">${fmtTick(v)}</text>`)
      .join("");
    const xLabels = xTicks
      .map((m) => `<text x="${x(Math.min(m, n - 1)).toFixed(1)}" y="${H - 32}" text-anchor="middle" font-size="10" fill="#666">${m === 0 ? "Now" : `${m / 12}y`}</text>`)
      .join("");

    // Axis titles
    const xAxisTitle = `<text x="${PAD_L + innerW / 2}" y="${H - 10}" text-anchor="middle" font-size="11" fill="#444">Years from now</text>`;
    const yAxisTitle = `<text x="${14}" y="${PAD_T + innerH / 2}" text-anchor="middle" font-size="11" fill="#444" transform="rotate(-90, 14, ${PAD_T + innerH / 2})">Cumulative interest</text>`;

    svg.innerHTML = `
      ${gridLines}
      ${yLabels}
      ${xLabels}
      ${xAxisTitle}
      ${yAxisTitle}
      <path d="${toPath(fixedSeries)}" fill="none" stroke="#1f6feb" stroke-width="2" />
      <path d="${toPath(varSeries)}" fill="none" stroke="#d97706" stroke-width="2" />
    `;
  }

  function capitalize(s: string) {
    return s.charAt(0).toUpperCase() + s.slice(1);
  }

  function applyTodaysRates() {
    (form!.elements.namedItem("fixedRate") as HTMLInputElement).value = form!.dataset.defaultFixed!;
    (form!.elements.namedItem("variableRate") as HTMLInputElement).value = form!.dataset.defaultVar!;
    recalc();
  }

  form.addEventListener("input", recalc);
  form.querySelector('[data-action="use-rates"]')?.addEventListener("click", applyTodaysRates);
  form.querySelectorAll<HTMLButtonElement>("[data-preset]").forEach((btn) => {
    btn.addEventListener("click", () => applyPreset(btn.dataset.preset!));
  });
  recalc();
</script>

<style>
  .be-headline {
    font-size: 1.3rem;
    font-weight: 600;
    margin: 0 0 0.4rem;
  }
  .be-sub {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.9rem;
  }
  .be-detail {
    width: 100%;
    border-collapse: collapse;
  }
  .be-detail td {
    padding: 0.3rem 0;
    font-size: 0.9rem;
    border-bottom: 1px solid var(--color-border, #eee);
  }
  .be-detail td:last-child {
    text-align: right;
    font-variant-numeric: tabular-nums;
  }
  .be-chart {
    display: block;
    width: 100%;
    height: auto;
    margin-top: 0.75rem;
    max-width: 360px;
  }
  .be-legend {
    display: flex;
    gap: 1rem;
    font-size: 0.8rem;
    margin-top: 0.25rem;
    color: var(--color-muted);
  }
  .be-legend__item {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }
  .be-legend__item::before {
    content: "";
    display: inline-block;
    width: 12px;
    height: 2px;
  }
  .be-legend__item--fixed::before {
    background: #1f6feb;
  }
  .be-legend__item--variable::before {
    background: #d97706;
  }
  .be-presets {
    border: none;
    padding: 0;
    margin: 0 0 0.5rem;
  }
  .be-presets legend {
    font-size: 0.85rem;
    color: var(--color-muted);
    padding: 0;
    margin-bottom: 0.3rem;
  }
  .be-presets__row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .be-presets button {
    font-size: 0.85rem;
    padding: 0.3rem 0.6rem;
    border: 1px solid var(--color-border, #ccc);
    background: #fafafa;
    border-radius: 4px;
    cursor: pointer;
  }
  .be-presets button:hover {
    background: #f0f0f0;
  }
  .be-help {
    font-weight: normal;
    color: var(--color-muted);
    font-size: 0.8rem;
  }
  .be-pace {
    border: none;
    padding: 0;
    margin: 0.5rem 0;
  }
  .be-pace legend {
    font-size: 0.85rem;
    color: var(--color-muted);
    padding: 0;
    margin-bottom: 0.3rem;
  }
  .be-pace label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    margin: 0;
    padding: 0.35rem 0;
    min-height: 2rem;
    font-weight: normal;
    line-height: 1.3;
    cursor: pointer;
  }
  .be-pace input[type="radio"] {
    width: 18px;
    height: 18px;
    margin: 0;
    padding: 0;
    flex: 0 0 auto;
  }
  .be-totals {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 0.25rem 1rem;
    margin: 0.75rem 0 0;
    padding-top: 0.5rem;
    border-top: 1px solid var(--color-border, #eee);
    font-size: 0.9rem;
  }
  .be-totals > div {
    display: contents;
  }
  .be-totals dt {
    margin: 0;
    color: var(--color-muted);
  }
  .be-totals dd {
    margin: 0;
    text-align: right;
    font-variant-numeric: tabular-nums;
    font-weight: 600;
  }
</style>
