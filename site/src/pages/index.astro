---
import Base from "@layouts/Base.astro";
import Disclaimer from "@components/Disclaimer.astro";
import GuideCard from "@components/GuideCard.astro";
import HeroFeaturedRates from "@components/HeroFeaturedRates.astro";
import RateHistoryChart from "@components/RateHistoryChart.astro";
import RateTable from "@components/RateTable.astro";
import { formatUpdatedAt } from "@lib/format";
import { getAllGuides } from "@lib/guides";
import { loadRatesData } from "@lib/rates";

const data = await loadRatesData();
const guides = await getAllGuides();
guides.sort((a, b) => a.data.title.localeCompare(b.data.title));
---

<Base
  title="Canadian Rates | Compare today's posted and discounted rates"
  description="Compare current Canadian mortgage rates from major banks. Posted rates and the bank's own published discounted rates, updated daily."
  canonical="https://canadianrates.ca/"
>
  <HeroFeaturedRates data={data} />

  <section class="rates-section">
    <h2>All lender rates</h2>
    <p class="muted">
      Updated {formatUpdatedAt(data.updated_at)}. Posted rates are the public
      rates each lender advertises; discounted rates are the bank's own
      special-offer rates published alongside posted. Both come directly from
      the lender. See our <a href="/methodology">methodology</a>.
    </p>
    <Disclaimer variant="rate" />
    <RateTable data={data} terms={["3yr_fixed", "5yr_fixed", "variable"]} defaultSort="5yr_fixed" provinceFilter />
    <p>
      <a href="/rates/5-year-fixed">See full 5-year fixed rankings →</a>
    </p>
  </section>

  <RateHistoryChart
    terms={["5yr_fixed", "3yr_fixed", "variable"]}
    heading="Rate trend (best discounted)"
    caption="Lowest discounted rate across tracked lenders, by day."
  />

  <section class="learn-section">
    <h2>Learn before you choose</h2>
    <p class="muted">Plain-English guides covering the decisions every Canadian homeowner faces.</p>
    <div class="learn-grid">
      {guides.map((g) => (
        <GuideCard
          href={`/guides/${g.slug}`}
          title={g.data.title}
          description={g.data.description}
        />
      ))}
    </div>
    <p>
      <a href="/guides">All guides →</a>
    </p>
  </section>

  <section class="tools-section">
    <h2>Calculators</h2>
    <p class="muted">Run the numbers before you talk to a lender or broker.</p>
    <div class="tools-grid">
      <a class="tool-card" href="/calculator">
        <h3 class="tool-card__title">Payment</h3>
        <p class="tool-card__desc">Estimate your monthly mortgage payment, total interest, and CMHC premium.</p>
        <span class="tool-card__cta">Open →</span>
      </a>
      <a class="tool-card" href="/guides/affordability">
        <h3 class="tool-card__title">Affordability</h3>
        <p class="tool-card__desc">See your maximum approval based on GDS/TDS ratios and the federal stress test.</p>
        <span class="tool-card__cta">Open →</span>
      </a>
      <a class="tool-card" href="/guides/fixed-vs-variable">
        <h3 class="tool-card__title">Fixed vs Variable</h3>
        <p class="tool-card__desc">Model the break-even point between locking in a fixed rate and riding a variable.</p>
        <span class="tool-card__cta">Open →</span>
      </a>
      <a class="tool-card" href="/guides/break-the-mortgage">
        <h3 class="tool-card__title">Break Penalty</h3>
        <p class="tool-card__desc">Estimate the 3-month-interest or IRD penalty before you break a closed mortgage to refinance.</p>
        <span class="tool-card__cta">Open →</span>
      </a>
    </div>
  </section>
</Base>

<style>
  .rates-section {
    margin: 2rem 0;
  }
  .learn-section {
    margin: 2rem 0;
  }
  .learn-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1rem;
    margin: 1rem 0;
  }
  .tools-section {
    margin: 2rem 0;
  }
  .tools-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
    margin: 1rem 0;
  }
  .tool-card {
    display: block;
    padding: 1rem 1.25rem;
    border: 1px solid var(--color-border, #e0e4e8);
    border-radius: 8px;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s, transform 0.15s;
  }
  .tool-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
  }
  .tool-card__title {
    margin: 0 0 0.4rem;
    font-size: 1.1rem;
  }
  .tool-card__desc {
    margin: 0 0 0.6rem;
    font-size: 0.9rem;
    color: var(--color-muted);
  }
  .tool-card__cta {
    font-size: 0.85rem;
    color: var(--color-accent);
  }
  .muted {
    color: var(--color-muted);
    font-size: 0.95rem;
  }
</style>
