---
import { bestRateForTerm, loadRatesData } from "@lib/rates";

const data = await loadRatesData();
const best = bestRateForTerm(data, "5yr_fixed");
const defaultRate = best?.rate.discounted ?? 5.0;
---

<form class="calculator" data-default-rate={defaultRate}>
  <h2 class="calculator__title">Mortgage Payment Calculator</h2>
  <div class="calculator__grid">
    <label class="calculator__field">
      Home price
      <input type="number" name="homePrice" min="0" step="1000" value="600000" required />
    </label>

    <label class="calculator__field">
      Down payment %
      <input type="number" name="downPct" min="5" max="90" step="0.5" value="20" required />
    </label>

    <label class="calculator__field">
      Rate %
      <input type="number" name="rate" min="0" max="20" step="0.01" value={defaultRate} required />
    </label>

    <label class="calculator__field">
      Amortization (years)
      <select name="amortization">
        <option value="5">5</option>
        <option value="10">10</option>
        <option value="15">15</option>
        <option value="20">20</option>
        <option value="25" selected>25</option>
        <option value="30">30</option>
      </select>
    </label>

    <label class="calculator__field">
      Frequency
      <select name="frequency">
        <option value="monthly" selected>Monthly</option>
        <option value="biweekly">Bi-weekly</option>
        <option value="accelerated_biweekly">Accelerated bi-weekly</option>
      </select>
    </label>
  </div>

  <div class="calculator__results" aria-live="polite" aria-atomic="true">
    <div class="calculator__result">
      <span class="calculator__result-label">Payment</span>
      <span class="calculator__result-value" data-result="payment">$0</span>
    </div>
    <div class="calculator__result">
      <span class="calculator__result-label">CMHC premium</span>
      <span class="calculator__result-value" data-result="cmhc">$0</span>
    </div>
    <div class="calculator__result">
      <span class="calculator__result-label">Total interest</span>
      <span class="calculator__result-value" data-result="interest">$0</span>
    </div>
    <div class="calculator__result">
      <span class="calculator__result-label">Total cost</span>
      <span class="calculator__result-value" data-result="total">$0</span>
    </div>
  </div>

  <figure class="calculator__chart">
    <figcaption class="calculator__chart-caption">Balance and cumulative interest over the amortization</figcaption>
    <svg data-chart viewBox="0 0 480 280" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Mortgage balance and cumulative interest over the amortization period."></svg>
    <div class="calculator__chart-legend">
      <span class="calculator__chart-legend-item calculator__chart-legend-item--balance">Remaining balance</span>
      <span class="calculator__chart-legend-item calculator__chart-legend-item--interest">Cumulative interest</span>
    </div>
  </figure>
</form>

<script>
  import { buildAmortization, calculateMortgage, type Frequency } from "@lib/calculator";
  import { formatCurrency } from "@lib/format";

  const form = document.querySelector<HTMLFormElement>(".calculator");
  if (!form) throw new Error("calculator form not found");

  function read(name: string): number {
    const el = form!.elements.namedItem(name) as HTMLInputElement | HTMLSelectElement;
    return parseFloat(el.value);
  }

  function readString(name: string): string {
    const el = form!.elements.namedItem(name) as HTMLInputElement | HTMLSelectElement;
    return el.value;
  }

  function setText(selector: string, value: string) {
    const el = form!.querySelector(selector);
    if (el) el.textContent = value;
  }

  function recalc() {
    try {
      const input = {
        homePrice: read("homePrice"),
        downPaymentPct: read("downPct") / 100,
        annualRatePct: read("rate"),
        amortizationYears: read("amortization"),
        frequency: readString("frequency") as Frequency,
      };
      const result = calculateMortgage(input);
      setText("[data-result='payment']", formatCurrency(result.payment, { cents: true }));
      setText("[data-result='cmhc']", formatCurrency(result.cmhcPremium));
      setText("[data-result='interest']", formatCurrency(result.totalInterest));
      setText("[data-result='total']", formatCurrency(result.totalPaid));
      const sched = buildAmortization(input);
      drawChart(sched.balance, sched.cumulativeInterest, sched.paymentsPerYear, input.amortizationYears);
      updateUrl();
    } catch (err) {
      // Most likely: down payment < 5%. Show dashes rather than crashing.
      setText("[data-result='payment']", "—");
      setText("[data-result='cmhc']", "—");
      setText("[data-result='interest']", "—");
      setText("[data-result='total']", "—");
      drawChart([], [], 12, 0);
    }
  }

  function drawChart(balance: number[], cumInterest: number[], paymentsPerYear: number, years: number) {
    const svg = form!.querySelector<SVGSVGElement>("[data-chart]");
    if (!svg) return;
    if (balance.length === 0 || years === 0) {
      svg.innerHTML = "";
      return;
    }
    const W = 480, H = 280;
    const PAD_L = 64, PAD_R = 12, PAD_T = 14, PAD_B = 52;
    const innerW = W - PAD_L - PAD_R;
    const innerH = H - PAD_T - PAD_B;
    const n = balance.length;
    const maxY = Math.max(balance[0], cumInterest[cumInterest.length - 1], 1);
    const x = (i: number) => PAD_L + (i / (n - 1)) * innerW;
    const y = (v: number) => PAD_T + innerH - (v / maxY) * innerH;
    const toPath = (series: number[]) =>
      series.map((v, i) => `${i === 0 ? "M" : "L"} ${x(i).toFixed(1)} ${y(v).toFixed(1)}`).join(" ");

    const yTicks = 4;
    const yTickValues = Array.from({ length: yTicks + 1 }, (_, i) => (maxY * i) / yTicks);
    const fmtTick = (v: number) =>
      v >= 1000 ? `$${Math.round(v / 1000)}k` : `$${Math.round(v)}`;

    // X-tick spacing: every 5 years for amortizations >= 15, every year otherwise.
    const xTickStep = years >= 15 ? 5 : years >= 8 ? 2 : 1;
    const xTickPeriods: number[] = [];
    for (let yr = 0; yr <= years; yr += xTickStep) xTickPeriods.push(yr * paymentsPerYear);
    if (xTickPeriods[xTickPeriods.length - 1] !== years * paymentsPerYear) {
      xTickPeriods.push(years * paymentsPerYear);
    }

    const gridLines = yTickValues
      .map((v) => `<line x1="${PAD_L}" x2="${W - PAD_R}" y1="${y(v).toFixed(1)}" y2="${y(v).toFixed(1)}" stroke="#eee" stroke-width="1" />`)
      .join("");
    const yLabels = yTickValues
      .map((v) => `<text x="${PAD_L - 6}" y="${(y(v) + 4).toFixed(1)}" text-anchor="end" font-size="10" fill="#666">${fmtTick(v)}</text>`)
      .join("");
    const xLabels = xTickPeriods
      .map((p) => `<text x="${x(Math.min(p, n - 1)).toFixed(1)}" y="${H - 32}" text-anchor="middle" font-size="10" fill="#666">${p === 0 ? "Now" : `${p / paymentsPerYear}y`}</text>`)
      .join("");
    const xAxisTitle = `<text x="${PAD_L + innerW / 2}" y="${H - 10}" text-anchor="middle" font-size="11" fill="#444">Years from now</text>`;
    const yAxisTitle = `<text x="14" y="${PAD_T + innerH / 2}" text-anchor="middle" font-size="11" fill="#444" transform="rotate(-90, 14, ${PAD_T + innerH / 2})">Dollars</text>`;

    svg.innerHTML = `
      ${gridLines}
      ${yLabels}
      ${xLabels}
      ${xAxisTitle}
      ${yAxisTitle}
      <path d="${toPath(balance)}" fill="none" stroke="#1f6feb" stroke-width="2" />
      <path d="${toPath(cumInterest)}" fill="none" stroke="#d97706" stroke-width="2" />
    `;
  }

  function updateUrl() {
    const url = new URL(window.location.href);
    url.searchParams.set("price", String(read("homePrice")));
    url.searchParams.set("down", String(read("downPct")));
    url.searchParams.set("rate", String(read("rate")));
    url.searchParams.set("am", String(read("amortization")));
    url.searchParams.set("freq", readString("frequency"));
    window.history.replaceState({}, "", url);
  }

  function applyUrl() {
    const params = new URLSearchParams(window.location.search);
    const map: Record<string, string> = {
      price: "homePrice",
      down: "downPct",
      rate: "rate",
      am: "amortization",
      freq: "frequency",
    };
    for (const [param, name] of Object.entries(map)) {
      const v = params.get(param);
      if (v === null) continue;
      const el = form!.elements.namedItem(name) as HTMLInputElement | HTMLSelectElement;
      if (el) el.value = v;
    }
  }

  applyUrl();
  recalc();
  form.addEventListener("input", recalc);
  form.addEventListener("change", recalc);
</script>
