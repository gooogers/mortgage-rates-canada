---
import { loadRateHistory, seriesForTerm, type HistoryPoint } from "@lib/rateHistory";
import { formatTermLabel } from "@lib/format";
import type { Term } from "@lib/rates";

interface Props {
  /** Terms to plot. Each gets its own line in a shared chart. */
  terms: Term[];
  /** Optional override of the chart heading. */
  heading?: string;
  /** Optional caption rendered under the heading. */
  caption?: string;
  /** If set, only show points within this many days of the most recent. */
  windowDays?: number;
}

const { terms, heading = "Rate trend", caption, windowDays } = Astro.props;
const history = await loadRateHistory();

interface Series {
  term: Term;
  label: string;
  points: HistoryPoint[];
}

let series: Series[] = terms.map((t) => ({
  term: t,
  label: formatTermLabel(t),
  points: seriesForTerm(history, t),
}));

if (windowDays) {
  const allDates = series.flatMap((s) => s.points.map((p) => p.date));
  if (allDates.length > 0) {
    const last = allDates.sort()[allDates.length - 1];
    const cutoff = new Date(last);
    cutoff.setDate(cutoff.getDate() - windowDays);
    const cutoffIso = cutoff.toISOString().slice(0, 10);
    series = series.map((s) => ({
      ...s,
      points: s.points.filter((p) => p.date >= cutoffIso),
    }));
  }
}

const allPoints = series.flatMap((s) => s.points);
const totalPoints = allPoints.length;
const distinctDates = new Set(allPoints.map((p) => p.date));
const firstDate = totalPoints > 0 ? [...distinctDates].sort()[0] : null;
const lastDate =
  totalPoints > 0 ? [...distinctDates].sort()[distinctDates.size - 1] : null;

// Need at least two distinct dates per series to draw a meaningful line.
const hasEnoughData = distinctDates.size >= 2;

const COLORS = ["#1f6feb", "#d97706", "#16a34a", "#9333ea", "#ea580c"];

interface ChartShape {
  width: number;
  height: number;
  padL: number;
  padR: number;
  padT: number;
  padB: number;
}

const SHAPE: ChartShape = {
  width: 720,
  height: 260,
  padL: 56,
  padR: 16,
  padT: 16,
  padB: 50,
};
const innerW = SHAPE.width - SHAPE.padL - SHAPE.padR;
const innerH = SHAPE.height - SHAPE.padT - SHAPE.padB;

interface RenderedSeries extends Series {
  color: string;
  path: string;
}

let rendered: RenderedSeries[] = [];
let xLabels = "";
let yLabels = "";
let gridLines = "";

if (hasEnoughData) {
  const minRate = Math.min(...allPoints.map((p) => p.best));
  const maxRate = Math.max(...allPoints.map((p) => p.best));
  const pad = Math.max(0.1, (maxRate - minRate) * 0.1);
  const yMin = Math.max(0, minRate - pad);
  const yMax = maxRate + pad;

  const sortedDates = [...distinctDates].sort();
  const firstMs = new Date(sortedDates[0]).getTime();
  const lastMs = new Date(sortedDates[sortedDates.length - 1]).getTime();
  const span = Math.max(1, lastMs - firstMs);

  const xFor = (date: string) =>
    SHAPE.padL + ((new Date(date).getTime() - firstMs) / span) * innerW;
  const yFor = (rate: number) =>
    SHAPE.padT + innerH - ((rate - yMin) / (yMax - yMin)) * innerH;

  rendered = series
    .filter((s) => s.points.length >= 2)
    .map((s, i) => {
      const path = s.points
        .map((p, j) => `${j === 0 ? "M" : "L"} ${xFor(p.date).toFixed(1)} ${yFor(p.best).toFixed(1)}`)
        .join(" ");
      return { ...s, color: COLORS[i % COLORS.length], path };
    });

  // Y ticks: 4 evenly-spaced rate values.
  const yTickCount = 4;
  const yTicks = Array.from({ length: yTickCount + 1 }, (_, i) =>
    yMin + ((yMax - yMin) * i) / yTickCount,
  );
  yLabels = yTicks
    .map(
      (v) =>
        `<text x="${SHAPE.padL - 6}" y="${(yFor(v) + 4).toFixed(1)}" text-anchor="end" font-size="10" fill="#666">${v.toFixed(2)}%</text>`,
    )
    .join("");
  gridLines = yTicks
    .map(
      (v) =>
        `<line x1="${SHAPE.padL}" x2="${SHAPE.width - SHAPE.padR}" y1="${yFor(v).toFixed(1)}" y2="${yFor(v).toFixed(1)}" stroke="#eee" stroke-width="1" />`,
    )
    .join("");

  // X ticks: roughly 6 evenly-spaced dates.
  const xTickCount = Math.min(6, sortedDates.length);
  const xTickIdx = Array.from({ length: xTickCount }, (_, i) =>
    Math.round((sortedDates.length - 1) * (i / Math.max(1, xTickCount - 1))),
  );
  const seenIdx = new Set<number>();
  xLabels = xTickIdx
    .filter((idx) => {
      if (seenIdx.has(idx)) return false;
      seenIdx.add(idx);
      return true;
    })
    .map((idx) => {
      const date = sortedDates[idx];
      const d = new Date(date);
      const label = d.toLocaleDateString("en-CA", {
        month: "short",
        year: "2-digit",
      });
      return `<text x="${xFor(date).toFixed(1)}" y="${SHAPE.height - 28}" text-anchor="middle" font-size="10" fill="#666">${label}</text>`;
    })
    .join("");
}
---

<section class="rate-history">
  <h2 class="rate-history__heading">{heading}</h2>
  {caption && <p class="rate-history__caption">{caption}</p>}

  {hasEnoughData ? (
    <>
      <svg
        class="rate-history__chart"
        viewBox={`0 0 ${SHAPE.width} ${SHAPE.height}`}
        xmlns="http://www.w3.org/2000/svg"
        role="img"
        aria-label="Historical best discounted mortgage rates over time."
      >
        <Fragment set:html={gridLines} />
        <Fragment set:html={yLabels} />
        <Fragment set:html={xLabels} />
        <text x={SHAPE.padL + innerW / 2} y={SHAPE.height - 8} text-anchor="middle" font-size="11" fill="#444">Date</text>
        <text x="14" y={SHAPE.padT + innerH / 2} text-anchor="middle" font-size="11" fill="#444" transform={`rotate(-90, 14, ${SHAPE.padT + innerH / 2})`}>Best discounted rate</text>
        {rendered.map((s) => (
          <path d={s.path} fill="none" stroke={s.color} stroke-width="2" />
        ))}
      </svg>
      <div class="rate-history__legend">
        {rendered.map((s) => (
          <span class="rate-history__legend-item">
            <span class="rate-history__legend-swatch" style={`background:${s.color}`} aria-hidden="true"></span>
            {s.label}
          </span>
        ))}
      </div>
      <p class="rate-history__footnote">
        Best discounted rate across tracked lenders, by date. Tracking since {firstDate}; latest snapshot {lastDate}.
      </p>
    </>
  ) : (
    <p class="rate-history__pending">
      Daily rate snapshots are being collected. The chart fills in as more days are tracked — check back soon.
    </p>
  )}
</section>

<style>
  .rate-history {
    margin: 1.5rem 0;
    padding: 1.25rem;
    border: 1px solid var(--color-border, #e0e4e8);
    border-radius: 8px;
    background: var(--color-surface, #fafbfc);
  }
  .rate-history__heading {
    margin: 0 0 0.4rem;
    font-size: 1.1rem;
  }
  .rate-history__caption {
    margin: 0 0 1rem;
    color: var(--color-muted);
    font-size: 0.9rem;
  }
  .rate-history__chart {
    display: block;
    width: 100%;
    height: auto;
    max-width: 720px;
  }
  .rate-history__legend {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin: 0.5rem 0;
    font-size: 0.85rem;
    color: var(--color-muted);
  }
  .rate-history__legend-item {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }
  .rate-history__legend-swatch {
    display: inline-block;
    width: 14px;
    height: 2px;
  }
  .rate-history__footnote {
    margin: 0.5rem 0 0;
    font-size: 0.8rem;
    color: var(--color-muted);
  }
  .rate-history__pending {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.9rem;
  }
</style>
