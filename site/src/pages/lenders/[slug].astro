---
import Base from "@layouts/Base.astro";
import Breadcrumb from "@components/Breadcrumb.astro";
import Disclaimer from "@components/Disclaimer.astro";
import LenderBadge from "@components/LenderBadge.astro";
import LenderFacts from "@components/LenderFacts.astro";
import RateHistoryChart from "@components/RateHistoryChart.astro";
import RelatedGuides from "@components/RelatedGuides.astro";
import TermFaq from "@components/TermFaq.astro";
import { formatPercent, formatTermLabel, formatUpdatedAt } from "@lib/format";
import { loadRatesData, type Lender, type Term } from "@lib/rates";
import { getLenderFacts, renderLenderIntro } from "@lib/lenderFacts";
import { buildLenderFaq } from "@lib/lenderFaq";
import {
  breadcrumbSchema,
  faqPageSchema,
  financialServiceSchema,
  type BreadcrumbItem,
} from "@lib/schemas";

export async function getStaticPaths() {
  const data = await loadRatesData();
  return data.lenders.map((lender) => ({
    params: { slug: lender.slug },
    props: { lender, allLenders: data.lenders, updatedAt: data.updated_at },
  }));
}

const { lender, allLenders, updatedAt } = Astro.props as {
  lender: Lender;
  allLenders: Lender[];
  updatedAt: string;
};
const facts = getLenderFacts(lender.slug);
const intro = facts ? renderLenderIntro(facts) : null;

// Cross-link to other lenders of similar standing. Same type first
// (Big 6 ↔ Big 6, monoline ↔ monoline, credit union ↔ credit union),
// then up to two "of any type" fillers if same-type is thin.
const sameType = allLenders
  .filter((l) => l.slug !== lender.slug && l.type === lender.type)
  .slice(0, 4);
const otherTypeFillers = allLenders
  .filter((l) => l.slug !== lender.slug && l.type !== lender.type)
  .slice(0, Math.max(0, 4 - sameType.length));
const compareLenders = [...sameType, ...otherTypeFillers].slice(0, 4);

// "vs other lenders" table: pick the most common comparison term that this
// lender publishes — 5-year fixed first (highest-volume queries), then variable,
// then 3-year. The table compares this lender's rate alongside the comparison
// set for the SAME term, so head-to-head queries ("CIBC vs BMO 5-year fixed")
// land on a page that answers the question on the page.
const COMPARE_TERM_PRIORITY: Term[] = ["5yr_fixed", "variable", "3yr_fixed"];
const compareTerm =
  COMPARE_TERM_PRIORITY.find((t) => lender.rates.some((r) => r.term === t)) ?? null;

interface CompareRow {
  lender: Lender;
  posted: number | null;
  discounted: number | null;
  effective: number;
  isCurrent: boolean;
}

let compareRows: CompareRow[] = [];
if (compareTerm) {
  const candidates = [lender, ...compareLenders];
  for (const l of candidates) {
    const r = l.rates.find((x) => x.term === compareTerm);
    if (!r) continue;
    const eff = r.discounted ?? r.posted;
    compareRows.push({
      lender: l,
      posted: r.posted,
      discounted: r.discounted,
      effective: eff,
      isCurrent: l.slug === lender.slug,
    });
  }
  compareRows.sort((a, b) => a.effective - b.effective);
}
const compareLabel = compareTerm ? formatTermLabel(compareTerm) : null;

// Cross-link to the rate-term page for every term this lender offers.
const TERM_TO_SLUG: Record<string, string> = {
  "1yr_fixed": "1-year-fixed",
  "2yr_fixed": "2-year-fixed",
  "3yr_fixed": "3-year-fixed",
  "4yr_fixed": "4-year-fixed",
  "5yr_fixed": "5-year-fixed",
  "7yr_fixed": "7-year-fixed",
  "10yr_fixed": "10-year-fixed",
  variable: "variable",
};
const termLinks = lender.rates
  .filter((r) => TERM_TO_SLUG[r.term])
  .map((r) => ({
    term: r.term,
    label: formatTermLabel(r.term),
    slug: TERM_TO_SLUG[r.term],
  }));

// Pick which terms to plot on the rate-history chart. We use 5yr fixed and
// variable as the universal benchmarks; fall back to whatever the lender
// publishes if neither is offered.
const HISTORY_TERMS_PRIORITY: Term[] = ["5yr_fixed", "variable", "3yr_fixed", "2yr_fixed"];
const historyTerms = HISTORY_TERMS_PRIORITY
  .filter((t) => lender.rates.some((r) => r.term === t))
  .slice(0, 2);

const isNationalBank = lender.slug === "national";

const faqItems = buildLenderFaq(lender, facts);

const pageUrl = `https://canadianrates.ca/lenders/${lender.slug}`;
const breadcrumbTrail: BreadcrumbItem[] = [
  { name: "Home", path: "/" },
  { name: "Lenders", path: "/lenders" },
  { name: lender.name, path: `/lenders/${lender.slug}` },
];
const pageSchemas: Record<string, unknown>[] = [
  breadcrumbSchema(breadcrumbTrail),
  financialServiceSchema({
    name: lender.name,
    url: lender.source_url,
    pageUrl,
  }),
];
if (faqItems.length > 0) {
  pageSchemas.push(faqPageSchema(faqItems));
}
---

<Base
  title={`${lender.name} Mortgage Rates`}
  description={`Current posted and discounted mortgage rates for ${lender.name}, updated daily.`}
  canonical={pageUrl}
  schemas={pageSchemas}
>
  <Breadcrumb trail={breadcrumbTrail} />
  <h1>{lender.name} Mortgage Rates</h1>
  <p class="muted">
    Source: <a href={lender.source_url} rel="noopener" target="_blank">{lender.source_url}</a>
    <br />
    Last updated {formatUpdatedAt(updatedAt)}.
  </p>

  {intro && <p class="lender-intro">{intro}</p>}

  <Disclaimer variant="rate" />

  <table class="rate-table">
    <thead>
      <tr>
        <th>Term</th>
        <th>Posted</th>
        <th>Discounted</th>
      </tr>
    </thead>
    <tbody>
      {lender.rates.map((rate) => (
        <tr class="lender-row">
          <td class="lender-row__name">{formatTermLabel(rate.term)}</td>
          <td><s class="lender-row__posted">{formatPercent(rate.posted)}</s></td>
          <td><strong class="lender-row__discounted">{formatPercent(rate.discounted)}</strong></td>
        </tr>
      ))}
    </tbody>
  </table>

  <section class="lender-context">
    <h2>Posted vs discounted rates: what to look at</h2>
    <p>
      The <strong>posted rate</strong> is the official sticker rate {lender.name} publishes.
      It's used for the federal mortgage stress test{lender.type === "big6" ? " and — for Big 6 banks — to calculate the interest-rate-differential (IRD) penalty if you break a closed fixed mortgage early" : ""}.
      The <strong>discounted rate</strong> is what {lender.name} will actually lend at to a typical qualified borrower; it's almost always the rate that matters for monthly payments.
    </p>
    {lender.type === "big6" && (
      <p class="muted">
        Because Big 6 IRD penalties are calculated against posted rates, a larger
        posted-to-discounted gap can mean a larger penalty if you break the mortgage
        before renewal — worth checking on the term you're considering.
      </p>
    )}
  </section>

  {historyTerms.length > 0 && (
    <RateHistoryChart
      terms={historyTerms}
      heading="Market rate trend (lowest discounted)"
      caption={`How the best discounted ${historyTerms.map((t) => formatTermLabel(t).toLowerCase()).join(" and ")} rate across tracked lenders has moved over time. ${lender.name}'s current rates are listed above.`}
    />
  )}

  {facts && <LenderFacts facts={facts} />}

  {facts && (
    <section class="lender-context">
      <h2>{lender.name} prepayment privileges</h2>
      <p>
        {lender.name} allows up to <strong>{facts.prepayment.lump_sum_pct}% of the original principal</strong> as a lump-sum prepayment each year without penalty.
        On a $500,000 mortgage, that's roughly <strong>${(500_000 * facts.prepayment.lump_sum_pct / 100).toLocaleString("en-CA")}</strong> per year.
        {facts.prepayment.payment_increase_pct >= 100
          ? " You can also double your regular payment without penalty."
          : ` You can also increase your regular payment by up to ${facts.prepayment.payment_increase_pct}% per year.`}
      </p>
      <p class="muted">
        Prepayment privileges and how they accumulate vary by product (open vs closed, fixed vs variable) — always confirm with your mortgage agreement.
      </p>
    </section>
  )}

  {compareTerm && compareRows.length > 1 && (
    <section class="lender-context">
      <h2>{lender.name} vs other lenders — {compareLabel}</h2>
      <p class="muted">
        Today's published {compareLabel?.toLowerCase()} rates from {lender.name} and similar lenders, sorted lowest first.
      </p>
      <table class="rate-table">
        <thead>
          <tr>
            <th>Lender</th>
            <th>Posted</th>
            <th>Discounted</th>
          </tr>
        </thead>
        <tbody>
          {compareRows.map((row) => (
            <tr class={`lender-row${row.isCurrent ? " lender-row--current" : ""}`}>
              <td class="lender-row__name">
                {row.isCurrent ? (
                  <strong>{row.lender.name}</strong>
                ) : (
                  <a href={`/lenders/${row.lender.slug}`}>{row.lender.name}</a>
                )}
              </td>
              <td><s class="lender-row__posted">{formatPercent(row.posted)}</s></td>
              <td><strong class="lender-row__discounted">{formatPercent(row.discounted)}</strong></td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>
  )}

  {lender.affiliate_url && (
    <p>
      <a class="cta" href={lender.affiliate_url} rel="sponsored noopener" target="_blank">
        Apply with {lender.name} →
      </a>
    </p>
  )}

  {isNationalBank && (
    <section class="lender-context">
      <h2>About {lender.name} for mortgages</h2>
      <p>
        National Bank's mortgage market is dual-channel. Retail and branch
        banking are concentrated in Quebec, but the broker channel
        (sometimes branded NBC Broker / NBI) is one of the most active
        national wholesale lenders in Canada — most BC, Alberta, and
        Ontario borrowers who end up with an NBC mortgage do so through
        a broker rather than a branch. If you see National Bank on a
        broker quote outside Quebec, that's why.
      </p>
    </section>
  )}

  <section class="lender-context">
    <h2>Best rates by term</h2>
    <p class="muted">
      See how {lender.name}'s rates compare to the rest of the market for
      each term they offer.
    </p>
    <ul class="lender-context__termlinks">
      {termLinks.map((t) => (
        <li>
          <a href={`/rates/${t.slug}`}>Best {t.label} rates →</a>
        </li>
      ))}
    </ul>
  </section>

  {compareLenders.length > 0 && (
    <section class="lender-context">
      <h2>Compare with other lenders</h2>
      <ul class="lender-context__compare">
        {compareLenders.map((l) => (
          <li>
            <a href={`/lenders/${l.slug}`}>
              <LenderBadge slug={l.slug} name={l.name} />
              <span>{l.name}</span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

  <TermFaq items={faqItems} />

  <RelatedGuides slugs={["affordability"]} />
</Base>

<style>
  .muted {
    color: var(--color-muted);
    font-size: 0.95rem;
  }
  .lender-intro {
    font-size: 1rem;
    line-height: 1.55;
    margin: 1rem 0 1.25rem;
  }
  .lender-context {
    margin: 2rem 0 0;
  }
  .lender-context h2 {
    font-size: 1.1rem;
    margin: 0 0 0.5rem;
  }
  .lender-context p {
    margin: 0 0 0.75rem;
    line-height: 1.6;
  }
  .lender-context__termlinks {
    list-style: none;
    padding: 0;
    margin: 0.5rem 0 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 0.4rem 1rem;
  }
  .lender-context__termlinks a {
    font-size: 0.95rem;
  }
  .lender-context__compare {
    list-style: none;
    padding: 0;
    margin: 0.5rem 0 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 0.5rem;
  }
  .lender-context__compare a {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.55rem 0.75rem;
    border: 1px solid var(--color-border, #e0e4e8);
    border-radius: 6px;
    color: var(--color-fg);
    text-decoration: none;
    transition: border-color 0.15s;
  }
  .lender-context__compare a:hover {
    border-color: var(--color-accent);
  }
  .lender-row--current {
    background: var(--color-surface, #f7f9fb);
  }
</style>
