---
import LenderRow from "@components/LenderRow.astro";
import { formatTermLabel } from "@lib/format";
import type { RatesData, Term } from "@lib/rates";

interface Props {
  data: RatesData;
  terms?: Term[];
  /** Term to sort by ascending on initial load. Defaults to first rate column. */
  defaultSort?: Term;
  /** Render the province dropdown above the table. */
  provinceFilter?: boolean;
}

const DEFAULT_TERMS: Term[] = ["3yr_fixed", "5yr_fixed", "variable"];
const { data, terms = DEFAULT_TERMS, defaultSort, provinceFilter = false } = Astro.props;
const initialSortKey = defaultSort && terms.includes(defaultSort) ? defaultSort : terms[0];

const PROVINCES: { code: string; name: string }[] = [
  { code: "AB", name: "Alberta" },
  { code: "BC", name: "British Columbia" },
  { code: "MB", name: "Manitoba" },
  { code: "NB", name: "New Brunswick" },
  { code: "NL", name: "Newfoundland and Labrador" },
  { code: "NS", name: "Nova Scotia" },
  { code: "NT", name: "Northwest Territories" },
  { code: "NU", name: "Nunavut" },
  { code: "ON", name: "Ontario" },
  { code: "PE", name: "Prince Edward Island" },
  { code: "QC", name: "Quebec" },
  { code: "SK", name: "Saskatchewan" },
  { code: "YT", name: "Yukon" },
];
---

<div class="rate-table-wrap">
  {provinceFilter && (
    <div class="rate-table__filter">
      <label for="province-select">Province</label>
      <select id="province-select" data-province-select>
        <option value="">All Canada</option>
        {PROVINCES.map((p) => (
          <option value={p.code}>{p.name}</option>
        ))}
      </select>
      <span class="rate-table__filter-hint" data-province-hint></span>
    </div>
  )}
  <table class="rate-table" data-sortable data-default-sort={initialSortKey}>
    <thead>
      <tr>
        <th>
          <button type="button" class="rate-table__sort" data-sort-key="name" data-sort-type="text">
            Lender <span class="rate-table__sort-indicator" aria-hidden="true"></span>
          </button>
        </th>
        {terms.map((t) => (
          <th>
            <button type="button" class="rate-table__sort" data-sort-key={t} data-sort-type="num">
              {formatTermLabel(t)} <span class="rate-table__sort-indicator" aria-hidden="true"></span>
            </button>
          </th>
        ))}
        <th></th>
      </tr>
    </thead>
    <tbody>
      {data.lenders.map((lender) => <LenderRow lender={lender} terms={terms} />)}
    </tbody>
  </table>
  <p class="rate-table__legend">
    <s>Posted</s> &nbsp; <strong>Discounted</strong>
  </p>
  <p class="rate-table__disclaimer">
    Discounted rates shown are bank-advertised special offers. Mortgage brokers may
    offer further discounts. Posted rates are used by federal stress tests; actual
    qualifying rates may differ.
  </p>
</div>

<style>
  .rate-table__disclaimer {
    margin-top: 1rem;
    font-size: 0.85rem;
    color: #6c757d;
    line-height: 1.4;
  }
  .rate-table__sort {
    background: none;
    border: 0;
    padding: 0.5rem 0;
    margin: 0;
    font: inherit;
    color: inherit;
    cursor: pointer;
    text-align: left;
    width: 100%;
    min-height: 2.75rem;
  }
  .rate-table__sort:hover {
    text-decoration: underline;
  }
  .rate-table__sort-indicator {
    display: inline-block;
    width: 0.7em;
    color: var(--color-muted);
    font-size: 0.85em;
  }
  .rate-table__sort[data-active="asc"] .rate-table__sort-indicator::before {
    content: "▲";
    color: var(--color-fg);
  }
  .rate-table__sort[data-active="desc"] .rate-table__sort-indicator::before {
    content: "▼";
    color: var(--color-fg);
  }
  .rate-table__filter {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0 0 0.75rem;
    font-size: 0.95rem;
  }
  .rate-table__filter label {
    font-weight: 600;
  }
  .rate-table__filter select {
    padding: 0.4rem 0.6rem;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    font: inherit;
    background: var(--color-bg);
  }
  .rate-table__filter-hint {
    font-size: 0.85rem;
    color: var(--color-muted);
  }
</style>

<script>
  function initSortableTables() {
    const tables = document.querySelectorAll<HTMLTableElement>("table[data-sortable]");
    tables.forEach((table) => {
      const tbody = table.tBodies[0];
      if (!tbody) return;
      const buttons = table.querySelectorAll<HTMLButtonElement>(".rate-table__sort");

      const sortBy = (key: string, type: string, dir: "asc" | "desc") => {
        const attr = `data-sort-${key}`;
        const rows = Array.from(tbody.rows);
        rows.sort((a, b) => {
          const av = a.getAttribute(attr) ?? "";
          const bv = b.getAttribute(attr) ?? "";
          if (type === "num") {
            const aEmpty = av === "";
            const bEmpty = bv === "";
            if (aEmpty && bEmpty) return 0;
            if (aEmpty) return 1;
            if (bEmpty) return -1;
            const an = Number(av);
            const bn = Number(bv);
            return dir === "asc" ? an - bn : bn - an;
          }
          const cmp = av.localeCompare(bv);
          return dir === "asc" ? cmp : -cmp;
        });
        rows.forEach((r) => tbody.appendChild(r));
        buttons.forEach((b) => b.removeAttribute("data-active"));
        const activeBtn = table.querySelector<HTMLButtonElement>(
          `.rate-table__sort[data-sort-key="${key}"]`,
        );
        if (activeBtn) activeBtn.dataset.active = dir;
      };

      buttons.forEach((btn) => {
        btn.addEventListener("click", () => {
          const key = btn.dataset.sortKey ?? "";
          const type = btn.dataset.sortType ?? "text";
          const current = btn.dataset.active;
          const next: "asc" | "desc" = current === "asc" ? "desc" : "asc";
          sortBy(key, type, next);
        });
      });

      const defaultKey = table.dataset.defaultSort;
      if (defaultKey) {
        sortBy(defaultKey, "num", "asc");
      }
    });
  }

  function applyProvinceFilter(province: string) {
    const tbodies = document.querySelectorAll<HTMLTableSectionElement>(
      "table[data-sortable] tbody",
    );
    tbodies.forEach((tbody) => {
      const rows = tbody.querySelectorAll<HTMLTableRowElement>("tr.lender-row");
      rows.forEach((row) => {
        const provs = (row.dataset.provinces ?? "").split(",").filter(Boolean);
        // National lenders (no provinces listed) always visible.
        // Provincial lenders: visible only when their province is selected.
        const isNational = provs.length === 0;
        const visible = isNational || (province !== "" && provs.includes(province));
        row.style.display = visible ? "" : "none";
      });
    });
  }

  function initProvinceFilter() {
    const select = document.querySelector<HTMLSelectElement>("[data-province-select]");
    if (!select) return;
    const hint = document.querySelector<HTMLSpanElement>("[data-province-hint]");

    const updateHint = (province: string) => {
      if (!hint) return;
      hint.textContent = province
        ? "Showing national lenders plus credit unions in this province."
        : "Showing national lenders only.";
    };

    const setProvince = (province: string, persist = true) => {
      select.value = province;
      applyProvinceFilter(province);
      updateHint(province);
      if (persist) {
        try {
          if (province) localStorage.setItem("province", province);
          else localStorage.removeItem("province");
        } catch {}
      }
    };

    select.addEventListener("change", () => setProvince(select.value));

    // Initial load: stored preference > IP-detected region > "All Canada".
    let stored: string | null = null;
    try {
      stored = localStorage.getItem("province");
    } catch {}
    if (stored) {
      setProvince(stored, false);
      return;
    }
    setProvince("", false);
    fetch("/api/region")
      .then((r) => (r.ok ? r.json() : null))
      .then((data) => {
        const region = data?.region as string | undefined;
        if (region && [...select.options].some((o) => o.value === region)) {
          // Auto-set without persisting — user hasn't explicitly chosen yet.
          setProvince(region, false);
        }
      })
      .catch(() => {});
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", () => {
      initSortableTables();
      initProvinceFilter();
    });
  } else {
    initSortableTables();
    initProvinceFilter();
  }
</script>
