---
import LenderBadge from "@components/LenderBadge.astro";
import { formatPercent, formatTermLabel, formatUpdatedAt } from "@lib/format";
import { bestRateForTermInScope, type BestRate, type RatesData, type Term } from "@lib/rates";

interface Props {
  data: RatesData;
  /** Which terms to feature in the hero. Defaults to 5yr fixed, 3yr fixed,
   *  and variable — the three terms ~90% of new originations pick. */
  featured?: Term[];
}

const DEFAULT_FEATURED: Term[] = ["5yr_fixed", "3yr_fixed", "variable"];
const { data, featured = DEFAULT_FEATURED } = Astro.props;
const lenderCount = data.lenders.length;

// Provinces represented by at least one provincial lender — the only scopes
// where the best rate could differ from national. Other provinces fall back
// to the national card.
const provincesWithLenders = new Set<string>();
for (const lender of data.lenders) {
  for (const code of lender.provinces ?? []) {
    provincesWithLenders.add(code);
  }
}
const scopes: string[] = ["", ...Array.from(provincesWithLenders).sort()];

const groups = featured.map((term) => ({
  term,
  cards: scopes
    .map((scope) => ({ scope, best: bestRateForTermInScope(data, term, scope) }))
    .filter((c): c is { scope: string; best: BestRate } => c.best !== null),
}));
---

<section class="hero">
  <h1 class="hero__title">Today's Lowest Canadian Mortgage Rates</h1>
  <p class="hero__sub">
    Posted and bank-published discounted rates from {lenderCount} Canadian lenders. Updated {formatUpdatedAt(data.updated_at)}.
  </p>
  <p class="hero__trust">
    Independent. No estimated rates — every figure comes straight from each lender's public rates page. <a href="/methodology">See methodology</a>.
  </p>
  <div class="hero__cards">
    {
      groups.map(({ term, cards }) => (
        <div class="hero-card-slot" data-hero-term={term}>
          {cards.map(({ scope, best }) => (
            <article
              class="hero-card"
              data-hero-card
              data-province={scope}
              hidden={scope !== "" ? true : undefined}
            >
              <p class="hero-card__label">Best {formatTermLabel(term)}</p>
              <p class="hero-card__rate">
                {formatPercent(best.rate.discounted ?? best.rate.posted)}
              </p>
              <p class="hero-card__lender">
                <LenderBadge slug={best.lender.slug} name={best.lender.name} />
                {best.lender.name}
              </p>
              {best.lender.affiliate_url ? (
                <a
                  class="cta"
                  href={best.lender.affiliate_url}
                  rel="sponsored noopener"
                  target="_blank"
                >
                  Get this rate →
                </a>
              ) : (
                <a class="cta cta--secondary" href={`/lenders/${best.lender.slug}`}>
                  View lender →
                </a>
              )}
            </article>
          ))}
        </div>
      ))
    }
  </div>
</section>

<style>
  .hero__sub {
    margin: 0.4rem 0 0.4rem;
    color: var(--color-fg);
    font-size: 1rem;
    line-height: 1.55;
    max-width: 60ch;
  }
  .hero__trust {
    margin: 0 0 1.25rem;
    color: var(--color-muted);
    font-size: 0.9rem;
    line-height: 1.55;
    max-width: 60ch;
  }
  .hero-card__lender {
    display: flex;
    align-items: center;
    gap: 6px;
  }
</style>

<script>
  function applyHeroProvince(province: string) {
    const slots = document.querySelectorAll<HTMLElement>("[data-hero-term]");
    slots.forEach((slot) => {
      const cards = slot.querySelectorAll<HTMLElement>("[data-hero-card]");
      // Prefer a province-specific card; fall back to the national card if
      // this province has no provincial lender (or no card was rendered for it).
      let target =
        slot.querySelector<HTMLElement>(
          `[data-hero-card][data-province="${province}"]`,
        ) ?? slot.querySelector<HTMLElement>('[data-hero-card][data-province=""]');
      cards.forEach((c) => {
        c.hidden = c !== target;
      });
    });
  }

  function initHeroProvince() {
    // Match RateTable's first-paint behavior: stored preference wins.
    let stored = "";
    try {
      stored = localStorage.getItem("province") ?? "";
    } catch {}
    if (stored) applyHeroProvince(stored);

    // RateTable broadcasts every province transition (manual change, stored
    // preference, IP-detected region) on this event.
    document.addEventListener("province-change", (e) => {
      const detail = (e as CustomEvent).detail;
      applyHeroProvince(detail?.province ?? "");
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initHeroProvince);
  } else {
    initHeroProvince();
  }
</script>
