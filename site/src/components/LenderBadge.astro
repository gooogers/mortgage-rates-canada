---
import { getLenderBrand } from "@lib/lenders";

interface Props {
  slug: string;
  name?: string;
}

const { slug, name } = Astro.props;
const brand = getLenderBrand(slug);
const altText = name ? `${name} logo` : `${brand.abbr} logo`;
---

{
  brand.logo ? (
    <img class="lender-logo" src={brand.logo} alt={altText} loading="lazy" decoding="async" />
  ) : (
    <span class="lender-badge" style={`background:${brand.bg}`} aria-hidden="true">
      {brand.abbr}
    </span>
  )
}

<style>
  .lender-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 6px;
    color: #fff;
    font-size: 10px;
    font-weight: 700;
    font-family: sans-serif;
    flex-shrink: 0;
    letter-spacing: -0.3px;
    line-height: 1;
  }
  .lender-logo {
    height: 28px;
    width: auto;
    max-width: 120px;
    flex-shrink: 0;
    object-fit: contain;
  }
</style>
