---
import Footer from "@components/Footer.astro";
import { isStaging } from "@lib/staging";
import { organizationSchema, SITE_URL, websiteSchema } from "@lib/schemas";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  /** Page-specific JSON-LD schemas; rendered after the sitewide ones. */
  schemas?: Record<string, unknown>[];
}

const { title, description, canonical, schemas = [] } = Astro.props;
const fullTitle = title.includes("Canadian Rates")
  ? title
  : `${title} — Canadian Rates`;
const staging = isStaging();
const allSchemas = [organizationSchema(), websiteSchema(), ...schemas];

// Open Graph + Twitter Card values. Falls back to sitewide defaults when a
// page doesn't supply description / canonical. og-image.svg lives in /public;
// a PNG twin would render on more social platforms but the SVG works on most
// modern crawlers (LinkedIn, Discord, Slack) and is bandwidth-cheap.
const ogUrl = canonical ?? SITE_URL;
const ogDescription =
  description ??
  "Compare current Canadian mortgage rates from major banks and provincial credit unions.";
const ogImage = `${SITE_URL}/og-image.svg`;
---

<!doctype html>
<html lang="en-CA">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    {description && <meta name="description" content={description} />}
    {canonical && <link rel="canonical" href={canonical} />}
    {staging && <meta name="robots" content="noindex, nofollow" />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Canadian Rates" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:url" content={ogUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_CA" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={ogImage} />

    {allSchemas.map((s) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}
  </head>
  <body>
    <header class="site-header">
      <a href="/" class="site-header__brand" aria-label="Canadian Rates — home">
        <svg viewBox="0 0 50 34" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
          <g fill="none" stroke-linecap="round" stroke-linejoin="round">
            <path d="M2 24 L24 4 L46 24" stroke="currentColor" stroke-width="3.5"/>
            <path d="M2 32 L46 32" stroke="#C8102E" stroke-width="2.5"/>
          </g>
        </svg>
        <span>Canadian Rates</span>
      </a>

      <button
        type="button"
        class="site-header__hamburger"
        aria-label="Toggle navigation menu"
        aria-controls="primary-nav"
        aria-expanded="false"
        data-nav-toggle
      >
        <span aria-hidden="true"></span>
        <span aria-hidden="true"></span>
        <span aria-hidden="true"></span>
      </button>

      <nav id="primary-nav" class="site-header__nav" data-primary-nav>
        <div class="nav-dropdown">
          <button
            type="button"
            class="nav-dropdown__trigger"
            aria-haspopup="true"
            aria-expanded="false"
            data-dropdown-trigger
          >Rates ▾</button>
          <ul class="nav-dropdown__menu" role="menu">
            <li role="none"><a role="menuitem" href="/rates"><strong>All rates</strong></a></li>
            <li role="none" class="nav-dropdown__divider" aria-hidden="true"></li>
            <li role="none"><a role="menuitem" href="/rates/5-year-fixed">5-year fixed</a></li>
            <li role="none"><a role="menuitem" href="/rates/3-year-fixed">3-year fixed</a></li>
            <li role="none"><a role="menuitem" href="/rates/variable">Variable</a></li>
            <li role="none"><a role="menuitem" href="/rates/other-terms">Other terms</a></li>
            <li role="none" class="nav-dropdown__divider" aria-hidden="true"></li>
            <li role="none"><a role="menuitem" href="/lenders">Lenders</a></li>
          </ul>
        </div>
        <a href="/provinces">Provinces</a>
        <a href="/guides">Guides</a>
        <div class="nav-dropdown">
          <button
            type="button"
            class="nav-dropdown__trigger"
            aria-haspopup="true"
            aria-expanded="false"
            data-dropdown-trigger
          >Calculators ▾</button>
          <ul class="nav-dropdown__menu" role="menu">
            <li role="none"><a role="menuitem" href="/calculators"><strong>All calculators</strong></a></li>
            <li role="none" class="nav-dropdown__divider" aria-hidden="true"></li>
            <li role="none"><a role="menuitem" href="/calculator">Payment</a></li>
            <li role="none"><a role="menuitem" href="/guides/affordability">Affordability</a></li>
            <li role="none"><a role="menuitem" href="/guides/fixed-vs-variable">Fixed vs Variable</a></li>
            <li role="none"><a role="menuitem" href="/guides/break-the-mortgage">Break Penalty</a></li>
            <li role="none"><a role="menuitem" href="/guides/closing-costs">Closing Costs</a></li>
          </ul>
        </div>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <Footer />

    <script>
      // Mobile nav + dropdown toggles. Works on touch (taps) and desktop
      // (clicks/keyboard); CSS still handles desktop hover.
      function initNav() {
        const hamburger = document.querySelector<HTMLButtonElement>("[data-nav-toggle]");
        const nav = document.querySelector<HTMLElement>("[data-primary-nav]");
        const dropdownTriggers = document.querySelectorAll<HTMLButtonElement>(
          "[data-dropdown-trigger]",
        );

        const closeAllDropdowns = (except?: HTMLButtonElement) => {
          dropdownTriggers.forEach((t) => {
            if (t === except) return;
            t.setAttribute("aria-expanded", "false");
            t.parentElement?.classList.remove("nav-dropdown--open");
          });
        };

        const closeMobileNav = () => {
          if (!hamburger || !nav) return;
          hamburger.setAttribute("aria-expanded", "false");
          nav.classList.remove("site-header__nav--open");
          closeAllDropdowns();
        };

        hamburger?.addEventListener("click", () => {
          if (!nav) return;
          const open = hamburger.getAttribute("aria-expanded") === "true";
          hamburger.setAttribute("aria-expanded", String(!open));
          nav.classList.toggle("site-header__nav--open", !open);
          if (open) closeAllDropdowns();
        });

        dropdownTriggers.forEach((trigger) => {
          trigger.addEventListener("click", (e) => {
            e.stopPropagation();
            const open = trigger.getAttribute("aria-expanded") === "true";
            closeAllDropdowns(open ? undefined : trigger);
            trigger.setAttribute("aria-expanded", String(!open));
            trigger.parentElement?.classList.toggle("nav-dropdown--open", !open);
          });
        });

        // Click outside closes everything.
        document.addEventListener("click", (e) => {
          const target = e.target as Element | null;
          if (!target) return;
          if (!target.closest("[data-primary-nav]") && !target.closest("[data-nav-toggle]")) {
            closeMobileNav();
          }
        });

        // Escape closes everything and refocuses the relevant trigger.
        document.addEventListener("keydown", (e) => {
          if (e.key !== "Escape") return;
          const anyOpen = [...dropdownTriggers].some(
            (t) => t.getAttribute("aria-expanded") === "true",
          );
          if (anyOpen || hamburger?.getAttribute("aria-expanded") === "true") {
            closeMobileNav();
            hamburger?.focus();
          }
        });
      }

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initNav);
      } else {
        initNav();
      }
    </script>
  </body>
</html>
